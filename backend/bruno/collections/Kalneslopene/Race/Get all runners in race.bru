meta {
  name: Get all runners in race
  type: http
  seq: 2
}

get {
  url: {{url}}/api/races/:uuid/runners
  body: text
  auth: inherit
}

params:path {
  uuid: b1000000-0000-0000-0000-000000000008
}

body:text {
  {
      "uuid": "a1000000-0000-0000-0000-000000000001",
      "name": "Eirik Solberg",
      "gender": "Mann"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
